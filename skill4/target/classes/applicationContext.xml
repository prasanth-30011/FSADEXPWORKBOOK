<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
       https://www.springframework.org/schema/beans
       https://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- Constructor Injection -->
    <bean id="studentConstructor" class="model.Student">
        <constructor-arg value="101"/>
        <constructor-arg value="Alice"/>
        <constructor-arg value="Computer Science"/>
        <constructor-arg value="2"/>
    </bean>

    <!-- Setter Injection -->
    <bean id="studentSetter" class="model.Student">
        <constructor-arg value="102"/>
        <constructor-arg value="Bob"/>
        <constructor-arg value="Physics"/>
        <constructor-arg value="1"/>

        <property name="course" value="Mathematics"/>
        <property name="year" value="3"/>
    </bean>

</beans>
